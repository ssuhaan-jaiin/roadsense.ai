# Copy to .env.local — Vite (client only; no secrets except public URLs).

# Production: your Render URL + path, e.g. https://roadsense-ai-api.onrender.com/api/gemini-insights
VITE_GEMINI_INSIGHT_URL=

# Default in code points at https://github.com/ssuhaan-jaiin/roadsense.ai
VITE_GITHUB_REPO_URL=

# Full site URL — no trailing slash. Required for WhatsApp/link previews (absolute og:image URL).
VITE_SITE_URL=

# Optional — India data.gov.in (api.data.gov.in). Explorer “live” ping uses GET .../resource/{UUID}.json?limit=1
# Keys are exposed in the browser if you use VITE_* ; prefer server proxy for production.
VITE_DATAGOV_KEY=
# Resource UUID from the dataset API page (defaults to a portal sample UUID if unset).
VITE_DATAGOV_RESOURCE_ID=

# Footer — optional overrides (defaults include ssuhaan.dev + university email)
VITE_CONTACT_WEBSITE_URL=
VITE_CONTACT_EMAIL=
VITE_LINKEDIN_URL=
VITE_GITHUB_CONTACT_URL=
